# Golden Codex × Kite — environment configuration
#
# Copy to `.env` and fill in the values you have. Anything missing falls back to
# stub mode where reasonable. The gcx-bar service is fully usable with NO secrets.
#
# To see the cocktail menu instantly without any setup:
#   docker-compose up gcx-bar
#   curl http://localhost:8080/menu | jq

# ---------------------------------------------------------------------------
# REQUIRED for the full 2-agent flow (Apprentice + Maestra)
# ---------------------------------------------------------------------------

# Twitter API bearer token (Apprentice X-watcher) — https://developer.twitter.com
X_BEARER_TOKEN=

# Anthropic API key (Maestra Claude reasoning) — https://console.anthropic.com
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-7

# ---------------------------------------------------------------------------
# OPTIONAL — falls back to public endpoints / stub mode if unset
# ---------------------------------------------------------------------------

# Kite Passport spending session JWT — kpass login init --email …
# (agents will run in unauthenticated read-only mode without this)
KITE_PASSPORT_JWT=

# Settlement vault address (treasury wallet on Base mainnet)
OPERATOR_VAULT=

# Cocktail Bar revenue wallet — Metavolve treasury, Base mainnet
GCX_BAR_PAY_TO=0xFE141943a93c184606F3060103D975662327063B

# x402 v2 facilitator URL — leave empty for STUB MODE (any X-Payment passes; useful for cold-start judges)
# Production: Coinbase CDP facilitator for Base mainnet (recommended).
# Testnet fallback: https://facilitator.pieverse.io for Kite Ozone testnet experiments.
GCX_BAR_FACILITATOR_URL=

# Multi-chain settlement — the bar advertises BOTH Kite mainnet 2366 (USDC.e)
# AND Base mainnet 8453 (USDC) in its x402 `accepts` envelope. Kite Passport's
# two-wallet routing lets an agent settle on whichever chain holds its funds.
GCX_BAR_NETWORK=eip155:8453
GCX_BAR_ASSET=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
GCX_BAR_KITE_NETWORK=eip155:2366
GCX_BAR_KITE_ASSET=0x7aB6f3ed87C42eF0aDb67Ed95090f8bF5240149e
X402_NETWORK=base

# Aegis hash-verification + register-api endpoints (live Cloud Run services)
AEGIS_URL=https://aegis-agent-172867820131.us-west1.run.app
REGISTER_API_URL=https://register-api-mrxpfmpeia-uw.a.run.app

# Cocktail Bar base URL (set to the deployed Cloud Run URL for production)
GCX_BAR_BASE_URL=http://localhost:8080

# ---------------------------------------------------------------------------
# OPTIONAL — Firestore decision logging
# ---------------------------------------------------------------------------

# Path to GCP service-account JSON file (leave default for stub-only run)
GCP_SA_PATH=/dev/null
GCP_PROJECT=the-golden-codex-1111
FIRESTORE_DB=golden-codex-database

# ---------------------------------------------------------------------------
# Maestra Frontier Lab mandate parameters
# ---------------------------------------------------------------------------

# Total quarterly procurement budget (USD)
MAESTRA_MANDATE_BUDGET_USD=250

# Tier filter — only consider Aeternum Assets at this GCX certification tier
MAESTRA_MANDATE_TIER=tier-1-gcx-certified

# Domain filter — what kind of training data the lab is hunting
MAESTRA_MANDATE_DOMAIN=vision-training

# Autonomous mode — true = no human-approval beat (Kite Buildathon demo default)
# Set to false to restore the prior collector's-broker flow with human approval
MAESTRA_AUTONOMOUS_MODE=true

# ---------------------------------------------------------------------------
# Demo pricing (real demo numbers; existing agent code uses 100x-reduced testnet fees)
# ---------------------------------------------------------------------------

# Pricing per Tad MacPherson's 2026-05-15 storyboard:
#  Phase 1 hash search:  $0.01 USDC  → Aegis
#  Phase 2 cocktail:     $0.01 USDC  → GCX Bar (Happy Hour for Passport holders)
#  Phase 3 license:      $1.00 USDC  → split $0.95 artist + $0.05 platform

DEMO_PRICING_VERIFY=0.01
DEMO_PRICING_COCKTAIL=0.10
DEMO_PRICING_LICENSE=1.00
DEMO_PRICING_ARTIST_SHARE=0.95
DEMO_PRICING_PLATFORM_FEE=0.05

# Happy Hour multiplier — verified Kite Passport holders get ½-off the cocktail price.
# Verifier is local (kite_passport_verify.py — EIP-712 ecrecover) so the bar is a
# permissionless merchant: no Kite catalog allowlist required.
GCX_BAR_HAPPY_HOUR_MULTIPLIER=0.5

